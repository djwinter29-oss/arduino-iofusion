# Doxyfile for arduino-iofusion / IOFusion

PROJECT_NAME           = "IOFusion"
PROJECT_BRIEF          = "Arduino-focused library for deterministic sampling and signal generation"
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO

# Inputs
INPUT                  = lib/IOFusion/include lib/IOFusion/src
FILE_PATTERNS          = *.h *.hpp *.c *.cpp
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */test/* */examples/* */apps/reference_firmware/*
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO

# Warnings
WARN_IF_UNDOCUMENTED   = NO
WARN_AS_ERROR          = NO

# Graphs
HAVE_DOT               = YES
DOT_NUM_THREADS        = 2
CLASS_DIAGRAMS         = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
UML_LOOK               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

# HTML
GENERATE_HTML          = YES
HTML_OUTPUT            = html

# LaTeX/PDF
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
PDF_HYPERLINKS         = YES
USE_PDFLATEX           = YES
LATEX_BATCHMODE        = YES

# Mermaid (doxygen 1.9.8 supports it if enabled)
HAVE_DOT               = YES
